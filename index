<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Learnify - AI Study Assistant</title>
    <style>
        :root {
            --bg-blue: #d0e7ff;
            --bg-pink: #fce4ec;
            --main-text: #1a3a5a;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #fff;
            overflow-x: hidden;
            min-height: 100vh;
            position: relative;
        }

        /* Decorative Backgrounds */
        .wave-blue {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 50%;
            height: 40%;
            background: var(--bg-blue);
            border-radius: 0 100% 0 0;
            z-index: -1;
        }

        .wave-pink {
            position: absolute;
            bottom: 0;
            right: 0;
            width: 60%;
            height: 50%;
            background: var(--bg-pink);
            border-radius: 100% 0 0 0;
            z-index: -2;
        }

        /* Header & Language Toggle */
        header {
            display: flex;
            justify-content: flex-end;
            padding: 20px;
        }

        .lang-btn {
            background-color: #0077b6;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-weight: bold;
        }

        /* Main Content */
        .container {
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 20px;
            text-align: center;
        }

        .logo {
            width: 120px;
            margin-bottom: 10px;
        }

        h1 {
            color: #0077b6;
            font-size: 3rem;
            margin: 0;
            font-style: italic;
        }

        /* Quick Guide Box */
        .guide-box {
            position: absolute;
            top: 100px;
            left: 40px;
            background: #f8d7da;
            padding: 15px;
            border-radius: 20px;
            width: 250px;
            text-align: left;
            font-size: 0.9rem;
            box-shadow: 2px 2px 10px rgba(0,0,0,0.1);
        }

        /* Upload Section */
        .upload-area {
            background: #e0e0e0;
            padding: 30px 60px;
            border-radius: 50px;
            margin-top: 30px;
            cursor: pointer;
            width: 400px;
        }

        .upload-area h2 {
            margin: 0;
            font-weight: normal;
        }

        .disclaimer {
            background: #fff9c4;
            padding: 5px 20px;
            margin-top: 20px;
            font-size: 0.8rem;
            border-radius: 5px;
        }

        /* Controls Section */
        .controls {
            margin-top: 30px;
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            justify-content: center;
        }

        select, button.action-btn {
            padding: 10px;
            border-radius: 10px;
            border: 1px solid #ccc;
        }

        /* Minigame Placeholder */
        .minigame-space {
            margin-top: 50px;
            width: 300px;
            height: 150px;
            border: 2px dashed #aaa;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #777;
            border-radius: 15px;
        }
    </style>
</head>
<body>

    <div class="wave-blue"></div>
    <div class="wave-pink"></div>

    <header>
        <button class="lang-btn" id="langToggle" onclick="toggleLanguage()">Bahasa Malaysia</button>
    </header>

    <aside class="guide-box" id="quickGuide">
        <strong>Quick Guide:</strong>
        <ul style="padding-left: 20px;">
            <li>1. Upload: Select a PDF or photo of notes.</li>
            <li>2. Question mode: Pick amount (5, 10, 20).</li>
            <li>3. Student mode: Hidden answers.</li>
            <li>4. Teacher mode: Answers visible.</li>
            <li>5. Translate: Rewrite notes into BM.</li>
        </ul>
    </aside>

    <main class="container">
        <img src="your-logo-path.png" alt="Learnify Logo" class="logo">
        <h1 id="siteTitle">Learnify</h1>

        <div class="upload-area" onclick="document.getElementById('fileInput').click()">
            <h2 id="uploadText">Upload PDF or image</h2>
            <input type="file" id="fileInput" style="display:none" accept="image/*,.pdf">
        </div>

        <div class="disclaimer" id="disclaimerText">
            Disclaimer: AI may occasionally provide incorrect information. Please cross-reference with your original source.
        </div>

        <div class="controls">
            <select id="questionCount">
                <option value="5">5 Questions</option>
                <option value="10">10 Questions</option>
                <option value="20">20 Questions</option>
            </select>
            
            <button class="action-btn" onclick="generateQuestions()">Generate Questions</button>
            <button class="action-btn" onclick="translateDoc()">Translate Document</button>
        </div>

        <!-- Space for results and Minigame -->
        <div id="resultArea"></div>

        <div class="minigame-space">
            Minigame Space
        </div>
    </main>

    <script>
        let currentLang = 'EN';

        function toggleLanguage() {
            const btn = document.getElementById('langToggle');
            const title = document.getElementById('siteTitle');
            const upload = document.getElementById('uploadText');
            const guide = document.getElementById('quickGuide');
            const disclaimer = document.getElementById('disclaimerText');

            if (currentLang === 'EN') {
                btn.innerText = "English";
                upload.innerText = "Muat naik PDF atau imej";
                disclaimer.innerText = "Penafian: AI mungkin memberikan maklumat yang salah. Sila rujuk sumber asal anda.";
                // Update Quick Guide content here
                currentLang = 'BM';
            } else {
                btn.innerText = "Bahasa Malaysia";
                upload.innerText = "Upload PDF or image";
                disclaimer.innerText = "Disclaimer: AI may occasionally provide incorrect information. Please cross-reference with your original source.";
                currentLang = 'EN';
            }
        }

        async function generateQuestions() {
            alert("Connecting to Gemini to generate " + document.getElementById('questionCount').value + " questions...");
            // Integrate your Gemini API call here
        }

        async function translateDoc() {
            alert("Translating document via Gemini...");
            // Integrate your Gemini API call here
        }
    </script>
</body>
</html>
